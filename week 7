      "source": [
        "# My Data Story: Weekly Shopping List\n",
        "# Week 8 - Files and Friends\n",
        "\n",
        "# File name\n",
        "filename = \"my_data.txt\"\n",
        "\n",
        "# Create the file with some example content if it doesn't exist\n",
        "# This ensures the program can run without FileNotFoundError\n",
        "with open(filename, \"w\") as file:\n",
        "    file.write(\"Milk\\n\")\n",
        "    file.write(\"Eggs\\n\")\n",
        "    file.write(\"Bread\\n\")\n",
        "    file.write(\"Apples\\n\")\n",
        "    file.write(\"Cheese\\n\")\n",
        "\n",
        "# Open and read the file\n",
        "with open(filename, \"r\") as file:\n",
        "    lines = file.readlines()\n",
        "\n",
        "# Remove extra spaces/newlines\n",
        "lines = [line.strip() for line in lines]\n",
        "\n",
        "# Display file contents\n",
        "print(\"=== MY DATA STORY ===\")\n",
        "print(\"\\nMy Shopping List:\\n\")\n",
        "\n",
        "for line in lines:\n",
        "    print(\"-\", line)\n",
        "\n",
        "# Calculate statistics\n",
        "num_lines = len(lines)\n",
        "num_words = sum(len(line.split()) for line in lines)\n",
        "longest_line = max(lines, key=len)\n",
        "\n",
        "# Display statistics\n",
        "print(\"\\n=== FILE STATISTICS ===\")\n",
        "print(\"Number of lines:\", num_lines)\n",
        "print(\"Total number of words:\", num_words)\n",
        "print(\"Longest line:\", longest_line)"
      ]
